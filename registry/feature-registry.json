  "features": [
    {
      "id": "auth-alpha-login",
      "title": "Private alpha account login",
      "summary": "Email, phone, QQ, and WeChat-style alpha login entry with account-password simulation.",
      "status": "implemented",
      "repo": "client/server",
      "lane": "server-auth",
      "ownerAi": "human",
      "verification": "local-pass",
      "uiSurfaces": [
        { "name": "Client login panel", "repo": "opc-bounty-client", "route": "/" },
        { "name": "Admin login shell", "repo": "opc-bounty-admin", "route": "/" }
      ],
      "operationChain": [
        "User selects login provider",
        "Server validates alpha account",
        "Client stores auth token",
        "Profile or admin shell renders allowed view"
      ],
      "linkedIssues": [],
      "discussionPrompt": "Which real OAuth or verification flow should be introduced first without breaking alpha account testing?"
    },
    {
      "id": "requirement-publishing",
      "title": "Requirement publishing workflow",
      "summary": "Requirement posting flow with materials, AI review, follow-up questions, draft generation, tags, save, and publish.",
