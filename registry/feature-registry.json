      "repo": "client/server",
      "lane": "client-publish",
      "ownerAi": "codex",
      "verification": "local-pass",
      "uiSurfaces": [
        { "name": "Publish requirement form", "repo": "opc-bounty-client", "route": "/#publish" },
        { "name": "Requirement draft editor", "repo": "opc-bounty-client", "route": "/#publish" }
      ],
      "operationChain": [
        "User submits requirement idea",
        "AI or mock review returns questions",
        "User answers and generates draft",
        "User selects tags and materials",
        "Server publishes posting to display board"
      ],
      "linkedIssues": [],
      "discussionPrompt": "Which parts of the publishing funnel need clearer review states before adding payment or external AI usage?"
    },
    {
